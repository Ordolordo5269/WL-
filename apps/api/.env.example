# WorldLore API — environment variables template
# Copy this file to .env and fill in the values. .env is gitignored.

# ── Core ──
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──
JWT_SECRET=replace_me_with_long_random_string

# ── External APIs ──

# Mapbox token for map rendering
MAPBOX_TOKEN=

# DeepSeek API key for AI features
DEEPSEEK_API_KEY=

# NASA FIRMS (fires) — free key from https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# UCDP (Uppsala Conflict Data Program) — ingestion
UCDP_API_TOKEN=

# Joshua Project (religions / languages) — ingestion
JOSHUA_PROJECT_API_KEY=

# NewsAPI — news ingestion
NEWS_API_KEY=

# RapidAPI — geo enrichment
RAPIDAPI_KEY=

# ── P6: Climate & Sustainability ingestion ──

# OpenAQ v3 — air quality monitoring station coverage
# Register at: https://explore.openaq.org
OPENAQ_API_KEY=

# Global Forest Watch — NOT required in current setup.
# We ingest via public OWID mirror (ourworldindata.org/grapher/tree-cover-loss).
# If OWID ever stops updating and you switch to GFW's official API, set this:
# GFW_API_KEY=
