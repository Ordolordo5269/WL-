generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityType {
  COUNTRY
  REGION
  CITY
  COMPANY
  INVESTOR
  PERSON
  MINE
  RESOURCE
  FACILITY
  PROJECT
  ORGANIZATION
  SECTOR
  PIPELINE
  PORT
  RAILWAY
  TREATY
}

enum RelationType {
  LOCATED_IN
  OWNS
  OPERATES
  INVESTS_IN
  EXTRACTS_RESOURCE
  SUPPLIES_TO
  TRANSPORTED_VIA
  PART_OF
  LICENSED_BY
  REGULATED_BY
  SANCTIONED_BY
  RELATED_TO
  MEMBER_OF
  OBSERVES
  SIGNATORY_TO
  RATIFIED
  APPLIES_TO
  DEPOSITORY
  COVERS_SECTOR
}

enum Frequency {
  ANNUAL
  QUARTERLY
  MONTHLY
  ONE_OFF
}

model Entity {
  id         String     @id @default(uuid()) @db.Uuid
  type       EntityType
  name       String
  slug       String     @unique
  iso2       String?    @db.VarChar(2)
  iso3       String?    @db.VarChar(3)
  isoNumeric Int?
  unM49      String?
  wbCode     String?
  region     String?
  subregion  String?
  country    String?
  lat        Float?
  lng        Float?
  validFrom  DateTime?
  validTo    DateTime?
  props      Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  fromRelations           Relation[]               @relation("From")
  toRelations             Relation[]               @relation("To")
  indicators              IndicatorValue[]
  // Back-relations for typed specs
  organizationSpec        OrganizationSpec?
  treatySpec              TreatySpec?
  mineSpec                MineSpec?
  resourceSpec            ResourceSpec?
  facilitySpec            FacilitySpec?
  companyProfile          CompanyProfile?
  // Back-relations for other models
  boundaries              Boundary[]
  tradeFrom               TradeFlow[]              @relation("TradeFrom")
  tradeTo                 TradeFlow[]              @relation("TradeTo")
  ownerHoldings           Ownership[]              @relation("Owner")
  ownedTargets            Ownership[]              @relation("Owned")
  infrastructureNodes     InfrastructureNode[]
  naturalFeatureCoverages NaturalFeatureCoverage[]
  financialMonthly        FinancialMarketMonthly[]

  @@index([type, country])
  @@index([name])
  @@index([iso3])
}

model Relation {
  id        String       @id @default(uuid())
  type      RelationType
  fromId    String       @db.Uuid
  toId      String       @db.Uuid
  from      Entity       @relation("From", fields: [fromId], references: [id])
  to        Entity       @relation("To", fields: [toId], references: [id])
  role      String?
  percent   Float?
  amount    Decimal?
  currency  String?
  startDate DateTime?
  endDate   DateTime?
  props     Json?
  sources   Json?
  createdAt DateTime     @default(now())

  @@index([type, fromId])
  @@index([type, toId])
  @@index([startDate, endDate])
}

model OrganizationSpec {
  entityId  String  @id @unique @db.Uuid
  entity    Entity  @relation(fields: [entityId], references: [id])
  orgType   String
  founded   Int?
  hqCountry String?
  website   String?
}

model TreatySpec {
  entityId       String    @id @unique @db.Uuid
  entity         Entity    @relation(fields: [entityId], references: [id])
  shortName      String?
  signedDate     DateTime?
  entryIntoForce DateTime?
  status         String?
  topics         Json?
  depository     String?
  referenceUrl   String?
}

model MineSpec {
  entityId  String  @id @unique @db.Uuid
  entity    Entity  @relation(fields: [entityId], references: [id])
  status    String?
  method    String?
  startYear Int?
  endYear   Int?
  elevation Int?
}

model ResourceSpec {
  entityId  String @id @unique @db.Uuid
  entity    Entity @relation(fields: [entityId], references: [id])
  commodity String
  unit      String
}

model FacilitySpec {
  entityId     String  @id @unique @db.Uuid
  entity       Entity  @relation(fields: [entityId], references: [id])
  facilityType String
  unitCapacity String?
}

model CompanyProfile {
  entityId  String  @id @unique @db.Uuid
  entity    Entity  @relation(fields: [entityId], references: [id])
  isin      String?
  ticker    String?
  hqCountry String?
  sector    String?
}

model Indicator {
  code        String    @id
  name        String
  topic       String?
  unit        String?
  frequency   Frequency @default(ANNUAL)
  source      String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  values IndicatorValue[]
}

model IndicatorValue {
  id                String    @id @default(uuid())
  entityId          String    @db.Uuid
  indicatorCode     String
  year              Int
  value             Decimal?
  meta              Json?
  source            String?
  revisedAt         DateTime?
  sourceVersion     String? // Native version from source: "v14", "CPI 2024", "WDI 2025Q1"
  sourceReleaseDate DateTime? // When the source published this version
  ingestedAt        DateTime  @default(now()) // When we put it in our DB

  entity    Entity    @relation(fields: [entityId], references: [id])
  indicator Indicator @relation(fields: [indicatorCode], references: [code])

  @@unique([entityId, indicatorCode, year])
  @@index([entityId, indicatorCode])
  @@index([indicatorCode, year])
}

/**
 * Prediction market snapshots (Polymarket and future sources).
 * Event-based data with lifecycle — does NOT fit (entity, indicator, year)
 * of IndicatorValue. Each row is a snapshot of a specific market at a
 * specific moment; re-ingest overwrites by marketSlug. When a market
 * resolves, `resolved=true` + `resolvedOutcome` lets the UI filter it
 * out silently without deleting history.
 */
model PredictionMarketSnapshot {
  id              String    @id @default(uuid())
  marketSlug      String    @unique // e.g. "will-the-us-invade-iran-before-2027"
  source          String // "Polymarket", future: "Kalshi", "Manifold"
  question        String
  category        String? // "Conflict" | "Elections" | "Macro" | "Diplomacy" | "Geopol"
  outcomes        Json? // ["Yes","No"] typically
  yesPrice        Decimal? // 0..1
  noPrice         Decimal? // 0..1
  probability     Decimal? // canonical "Yes" prob for quick sort (== yesPrice for binary)
  volume          Decimal? // lifetime traded volume
  liquidity       Decimal? // current liquidity
  closeDate       DateTime? // market resolution deadline
  resolved        Boolean   @default(false)
  resolvedOutcome String? // "Yes" | "No" | "50-50" once resolved
  snapshotAt      DateTime  @default(now()) // when we captured this snapshot
  sourceUrl       String? // deep-link to the market
  sourceVersion   String? // mirrors IndicatorValue field for traceability

  @@index([source, resolved, closeDate])
  @@index([category, resolved])
}

/**
 * Monthly financial time series — ML-grade granularity.
 * Coexists with IndicatorValue (annual). Dashboard reads annual,
 * ML models read monthly. Same indicator codes, different table.
 */
model FinancialMarketMonthly {
  id                String    @id @default(uuid())
  entityId          String    @db.Uuid
  indicatorCode     String
  year              Int
  month             Int // 1-12
  value             Decimal
  source            String
  sourceVersion     String?
  sourceReleaseDate DateTime?
  ingestedAt        DateTime  @default(now())

  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([entityId, indicatorCode, year, month])
  @@index([indicatorCode, year, month])
  @@index([entityId, indicatorCode])
}

model Boundary {
  id       String            @id @default(uuid())
  entityId String            @db.Uuid
  name     String
  versions BoundaryVersion[]
  entity   Entity            @relation(fields: [entityId], references: [id])
}

model BoundaryVersion {
  id         String    @id @default(uuid())
  boundaryId String
  validFrom  DateTime?
  validTo    DateTime?
  geojson    Json
  source     String?
  boundary   Boundary  @relation(fields: [boundaryId], references: [id])

  @@index([validFrom, validTo])
}

model TradeFlow {
  id       String   @id @default(uuid())
  year     Int
  fromId   String   @db.Uuid
  toId     String   @db.Uuid
  hsCode   String
  quantity Decimal?
  unit     String?
  valueUsd Decimal?
  route    String?

  from Entity @relation("TradeFrom", fields: [fromId], references: [id])
  to   Entity @relation("TradeTo", fields: [toId], references: [id])

  @@unique([fromId, toId, hsCode, year])
  @@index([fromId, year])
  @@index([toId, year])
  @@index([hsCode, year])
}

model Ownership {
  id        String    @id @default(uuid())
  holderId  String    @db.Uuid
  targetId  String    @db.Uuid
  percent   Float?
  startDate DateTime?
  endDate   DateTime?
  sources   Json?

  holder Entity @relation("Owner", fields: [holderId], references: [id])
  target Entity @relation("Owned", fields: [targetId], references: [id])

  @@index([holderId])
  @@index([targetId])
}

model InfrastructureNode {
  id       String   @id @default(uuid())
  type     String
  name     String
  entityId String?  @db.Uuid
  lat      Float?
  lng      Float?
  capacity Decimal?
  unit     String?
  props    Json?

  entity Entity? @relation(fields: [entityId], references: [id])

  @@index([type])
}

model InfrastructureEdge {
  id        String    @id @default(uuid())
  type      String
  fromNode  String
  toNode    String
  lengthKm  Float?
  capacity  Decimal?
  unit      String?
  validFrom DateTime?
  validTo   DateTime?
  geojson   Json?
  props     Json?

  @@index([type])
  @@index([validFrom, validTo])
}

// ============================
// Natural features (rivers, ranges, peaks)
// ============================

enum NaturalFeatureType {
  RIVER
  MOUNTAIN_RANGE
  PEAK
  LAKE
  VOLCANO
  FAULT_LINE
  DESERT
  CONTINENTAL_SHELF
  FOREST
}

enum NaturalLod {
  LOW
  MED
  HIGH
}

model NaturalFeature {
  id        String             @id @default(uuid())
  type      NaturalFeatureType
  name      String?
  slug      String             @unique
  props     Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  geometries NaturalGeometry[]
  coverage   NaturalFeatureCoverage[]

  @@index([type, name])
}

model NaturalGeometry {
  id        String     @id @default(uuid())
  featureId String
  lod       NaturalLod
  geojson   Json
  source    String?

  feature NaturalFeature @relation(fields: [featureId], references: [id])

  @@unique([featureId, lod])
  @@index([lod])
}

model NaturalFeatureCoverage {
  featureId String
  entityId  String @db.Uuid

  feature NaturalFeature @relation(fields: [featureId], references: [id])
  entity  Entity         @relation(fields: [entityId], references: [id])

  @@id([featureId, entityId])
  @@index([entityId])
}

// ============================
// Historical basemaps (DB-backed History Mode)
// ============================

enum HistoryLod {
  LOW
  MED
  HIGH
}

model HistoricalPolity {
  id            String  @id @default(uuid())
  canonicalKey  String  @unique
  displayName   String?
  colorHex      String?
  validFromYear Int?
  validToYear   Int?
  props         Json?

  areas HistoricalArea[]
}

model HistoricalArea {
  id              String  @id @default(uuid())
  year            Int
  name            String?
  canonicalName   String?
  borderPrecision Int?
  props           Json?
  polityId        String?

  polity     HistoricalPolity?        @relation(fields: [polityId], references: [id])
  geometries HistoricalAreaGeometry[]

  @@index([year])
}

model HistoricalAreaGeometry {
  id      String     @id @default(uuid())
  areaId  String
  lod     HistoryLod
  geojson Json
  source  String?

  area HistoricalArea @relation(fields: [areaId], references: [id])

  @@unique([areaId, lod])
}

// ============================
// Conflict Tracker
// ============================

enum ConflictStatus {
  ACTIVE
  FROZEN
  ENDED
}

enum ConflictType {
  INTERSTATE
  CIVIL_WAR
  INSURGENCY
  TERRITORIAL
  ETHNIC
  OTHER
}

enum FactionType {
  STATE
  MILITIA
  REBEL
  TERRORIST
  OTHER
}

enum SupportType {
  MILITARY
  DIPLOMATIC
  ECONOMIC
}

model Conflict {
  id                 String         @id @default(uuid())
  name               String
  countryIso         String         @db.VarChar(3)
  lng                Float
  lat                Float
  status             ConflictStatus
  type               ConflictType
  description        String?
  startDate          DateTime?
  endDate            DateTime?
  casualtiesEstimate Int?

  factions     ConflictFaction[]
  supportLinks SupportLink[]

  @@index([countryIso])
  @@index([status])
}

model Faction {
  id         String      @id @default(uuid())
  name       String
  type       FactionType
  countryIso String?     @db.VarChar(3)
  flagUrl    String?

  conflicts    ConflictFaction[]
  supportsFrom SupportLink[]     @relation("SupportFrom")
  supportsTo   SupportLink[]     @relation("SupportTo")
}

model ConflictFaction {
  conflictId String
  factionId  String
  side       String @db.VarChar(1) // 'A' | 'B' | 'C'
  casualties Int? // estimated casualties for this faction

  conflict Conflict @relation(fields: [conflictId], references: [id], onDelete: Cascade)
  faction  Faction  @relation(fields: [factionId], references: [id], onDelete: Cascade)

  @@id([conflictId, factionId])
  @@index([conflictId])
  @@index([factionId])
}

model SupportLink {
  id          Int         @id @default(autoincrement())
  conflictId  String
  fromId      String
  toId        String
  type        SupportType
  intensity   Int? // 1-3, controls line thickness
  description String?
  sourceUrl   String?
  startedAt   DateTime?
  endedAt     DateTime?

  conflict Conflict @relation(fields: [conflictId], references: [id], onDelete: Cascade)
  from     Faction  @relation("SupportFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to       Faction  @relation("SupportTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([conflictId])
  @@index([fromId])
  @@index([toId])
}

// ============================
// User Authentication & Favorites
// ============================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  favorites Favorite[]

  @@index([email])
}

model Favorite {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  countryIso3 String   @db.VarChar(3)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, countryIso3])
  @@index([userId])
  @@index([countryIso3])
}

// ============================
// OSINT Scraper Models
// ============================

enum OsintSeverity {
  CRITICAL
  HIGH
  ELEVATED
  MODERATE
  LOW
}

enum OsintMacroLayer {
  CONFLICT_SECURITY
  GOVERNANCE_DIPLOMACY
  ECONOMIC_COERCION
  HUMANITARIAN_DISASTER
  CYBER_INFO
}

model OsintEvent {
  id          String          @id @default(uuid()) @db.Uuid
  source      String          @db.Text
  sourceId    String?         @db.Text
  category    String          @db.Text
  macroLayer  OsintMacroLayer
  title       String          @db.Text
  summary     String?         @db.Text
  severity    OsintSeverity
  countryIso3 String?         @db.VarChar(3)
  countryIso2 String?         @db.VarChar(2)
  countryName String?         @db.Text
  region      String?         @db.Text
  lat         Float?
  lng         Float?
  eventDate   DateTime        @db.Timestamptz()
  url         String?         @db.Text
  rawData     Json?
  tags        String[]
  isAlert     Boolean         @default(false)
  hash        String          @unique @db.Text
  createdAt   DateTime        @default(now()) @db.Timestamptz()

  alerts OsintAlert[]

  @@index([severity, eventDate])
  @@index([countryIso3, category])
  @@index([macroLayer, severity])
  @@index([eventDate])
}

model OsintAlert {
  id                String        @id @default(uuid()) @db.Uuid
  eventId           String        @db.Uuid
  alertType         String        @db.Text
  severity          OsintSeverity
  title             String        @db.Text
  description       String?       @db.Text
  affectedCountries String[]
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now()) @db.Timestamptz()
  resolvedAt        DateTime?     @db.Timestamptz()

  event OsintEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([severity, isActive])
  @@index([eventId])
}

model OsintSource {
  id          String    @id @db.Text
  lastFetch   DateTime? @db.Timestamptz()
  status      String    @default("ok") @db.Text
  eventsCount Int       @default(0)
  errorLog    String?   @db.Text
}

model OsintScrapeLog {
  id               String    @id @default(uuid()) @db.Uuid
  startedAt        DateTime  @default(now()) @db.Timestamptz()
  finishedAt       DateTime? @db.Timestamptz()
  eventsFetched    Int       @default(0)
  eventsInserted   Int       @default(0)
  eventsDuplicated Int       @default(0)
  errors           Json?
}

// ============================
// Satellite Profiles
// ============================

model SatelliteProfile {
  id          Int      @id @default(autoincrement())
  pattern     String // regex pattern to match OBJECT_NAME (or country code for fallbacks)
  matchType   String   @default("pattern") @map("match_type") // "pattern" | "country"
  program     String
  operator    String
  purpose     String
  coverage    String
  orbitType   String   @map("orbit_type")
  description String   @db.Text
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("satellite_profiles")
}

// ============================
// GeoDB Cities API Cache
// ============================

model GeoCache {
  id        String   @id // format: "cities:{iso2}" or "regions:{iso2}"
  type      String // 'cities' | 'regions'
  iso2      String   @db.VarChar(2)
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime

  @@index([iso2])
  @@index([type])
  @@index([expiresAt])
}

// ============================
// Demographics: Languages (Joshua Project)
// ============================

model Language {
  id           String   @id @default(uuid()) @db.Uuid
  iso639_3     String   @unique @db.VarChar(3)
  name         String
  hubCountry   String?  @db.VarChar(3)
  nbrCountries Int      @default(0)
  speakers     BigInt   @default(0)
  status       String?
  family       String?
  officialIn   String[] @default([])
  lat          Float?
  lng          Float?
  jpData       Json?
  syncedAt     DateTime @default(now())

  @@index([family])
  @@index([status])
  @@index([speakers])
}

// ============================
// Demographics: Religion Stats (Joshua Project)
// ============================

model ReligionStat {
  id                 String   @id @default(uuid()) @db.Uuid
  countryIso3        String   @unique @db.VarChar(3)
  countryName        String?
  population         BigInt   @default(0)
  pctChristianity    Float    @default(0)
  pctIslam           Float    @default(0)
  pctBuddhism        Float    @default(0)
  pctHinduism        Float    @default(0)
  pctEthnicReligions Float    @default(0)
  pctNonReligious    Float    @default(0)
  pctOther           Float    @default(0)
  pctUnknown         Float    @default(0)
  primaryReligion    String?
  syncedAt           DateTime @default(now())

  @@index([primaryReligion])
}

// ============================
// Demographics: Migration Corridors (UNHCR)
// ============================

model MigrationCorridor {
  id               String   @id @default(uuid()) @db.Uuid
  originIso3       String   @db.VarChar(3)
  originName       String?
  destinationIso3  String   @db.VarChar(3)
  destinationName  String?
  year             Int
  refugees         Int      @default(0)
  asylumSeekers    Int      @default(0)
  returnedRefugees Int      @default(0)
  idps             Int      @default(0)
  stateless        Int      @default(0)
  otherOfConcern   Int      @default(0)
  otherInNeed      Int      @default(0)
  hostCommunity    Int      @default(0)
  syncedAt         DateTime @default(now())

  @@unique([originIso3, destinationIso3, year])
  @@index([originIso3])
  @@index([destinationIso3])
  @@index([year])
}

// ── Sanctions (OpenSanctions) ──────────────────────────────────────────────
model Sanction {
  id                String    @id @default(uuid())
  entityName        String // Person, company, vessel, etc.
  entityType        String    @db.VarChar(50) // person, company, vessel, aircraft, organization
  countryIso3       String?   @db.VarChar(3) // Country associated (nationality or registration)
  sanctionProgram   String // e.g. "OFAC SDN", "EU Consolidated", "UN Security Council"
  sanctionAuthority String    @db.VarChar(50) // OFAC, EU, UN, OFSI, CH, CA, AU
  reason            String? // Reason for listing
  listedAt          DateTime? // Date added to sanctions list
  delistedAt        DateTime? // Date removed (null = still active)
  isActive          Boolean   @default(true)
  sourceUrl         String?
  sourceId          String?   @unique // OpenSanctions entity ID for dedup
  props             Json? // Extra properties (aliases, addresses, etc.)
  syncedAt          DateTime  @default(now())

  @@index([countryIso3])
  @@index([sanctionAuthority])
  @@index([isActive])
  @@index([entityType])
}

// ── Electoral Calendar ─────────────────────────────────────────────────────
model ElectionCalendar {
  id             String    @id @default(uuid())
  countryIso3    String    @db.VarChar(3)
  countryName    String
  electionType   String    @db.VarChar(50) // presidential, parliamentary, legislative, referendum, local
  electionDate   DateTime? // Scheduled date (null if TBD)
  year           Int // Year of election
  status         String    @db.VarChar(30) // scheduled, completed, postponed, cancelled
  description    String? // e.g. "General election", "Senate runoff"
  turnoutPercent Float? // Voter turnout if completed (IDEA data)
  sourceUrl      String?
  props          Json? // Extra metadata
  syncedAt       DateTime  @default(now())

  @@unique([countryIso3, electionType, year])
  @@index([countryIso3])
  @@index([year])
  @@index([status])
  @@index([electionDate])
}
