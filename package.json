{
  "name": "worldlore",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "landing"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev --workspace=@worldlore/api",
    "dev:web": "npm run dev --workspace=@worldlore/web",
    "dev:landing": "npm run dev --workspace=landing",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react-is": "^19.2.4",
    "satellite.js": "^5.0.0"
  }
}
